# Environment-specific Terraform variables

# Development environment
aws_region = "us-east-1"
environment = "dev"

# Database configuration for development
db_instance_class = "db.t3.micro"
db_allocated_storage = 20
db_max_allocated_storage = 100
db_name = "cloud_optimizer"
db_username = "postgres"
# db_password should be set via environment variable or terraform.tfvars.local

# Redis configuration for development
redis_node_type = "cache.t3.micro"
redis_num_cache_nodes = 1
# redis_auth_token should be set via environment variable or terraform.tfvars.local

# Monitoring
backup_retention_days = 1
enable_monitoring = false
enable_deletion_protection = false

# Additional tags
additional_tags = {
  Owner = "development-team"
  Project = "cloud-cost-optimizer"
}
