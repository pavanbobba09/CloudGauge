# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/cloud_optimizer
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-at-least-64-characters-long
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=3001
NODE_ENV=development

# Cloud Provider API Keys
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# GCP Service Account (path to JSON file or JSON string)
GCP_SERVICE_ACCOUNT_KEY=path-to-your-gcp-service-account.json
GCP_PROJECT_ID=your-gcp-project-id

# Azure Configuration
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache TTL (Time To Live) in seconds
PRICING_CACHE_TTL=86400
USER_CACHE_TTL=3600

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Lambda Configuration (for AWS deployment)
LAMBDA_TIMEOUT=30
LAMBDA_MEMORY=512
