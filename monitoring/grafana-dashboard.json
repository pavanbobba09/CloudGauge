{
  "version": "0.0.1",
  "id": "cloud-cost-optimizer-dashboard",
  "title": "Cloud Cost Optimizer Monitoring",
  "tags": [
    "cloud-cost-optimizer",
    "monitoring",
    "production"
  ],
  "timezone": "UTC",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "API Response Times",
      "type": "graph",
      "targets": [
        {
          "expr": "avg_over_time(api_response_time_seconds[5m])",
          "legendFormat": "Average Response Time",
          "refId": "A"
        },
        {
          "expr": "max_over_time(api_response_time_seconds[5m])",
          "legendFormat": "Max Response Time",
          "refId": "B"
        }
      ],
      "yAxes": [
        {
          "label": "Seconds",
          "min": 0
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "API Request Rate",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(api_requests_total[5m])",
          "legendFormat": "Requests per second",
          "refId": "A"
        }
      ],
      "yAxes": [
        {
          "label": "Requests/sec",
          "min": 0
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Cache Hit Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(redis_cache_hits_total[5m]) / (rate(redis_cache_hits_total[5m]) + rate(redis_cache_misses_total[5m])) * 100",
          "legendFormat": "Cache Hit Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "title": "Cost Calculation Requests",
      "type": "stat",
      "targets": [
        {
          "expr": "increase(cost_calculation_requests_total[1h])",
          "legendFormat": "Calculations Last Hour",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 8
      }
    },
    {
      "id": 5,
      "title": "Lambda Function Duration",
      "type": "graph",
      "targets": [
        {
          "expr": "aws_lambda_duration_average{function_name=\"cloud-cost-optimizer-api\"}",
          "legendFormat": "Average Duration",
          "refId": "A"
        },
        {
          "expr": "aws_lambda_duration_maximum{function_name=\"cloud-cost-optimizer-api\"}",
          "legendFormat": "Max Duration",
          "refId": "B"
        }
      ],
      "yAxes": [
        {
          "label": "Milliseconds",
          "min": 0
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "id": 6,
      "title": "Lambda Errors",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(aws_lambda_errors_sum{function_name=\"cloud-cost-optimizer-api\"}[5m])",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "yAxes": [
        {
          "label": "Errors/sec",
          "min": 0
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 16
      }
    },
    {
      "id": 7,
      "title": "Database Connections",
      "type": "graph",
      "targets": [
        {
          "expr": "aws_rds_database_connections_average{db_instance_identifier=\"cloud-cost-optimizer-db\"}",
          "legendFormat": "Active Connections",
          "refId": "A"
        }
      ],
      "yAxes": [
        {
          "label": "Connections",
          "min": 0
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 16
      }
    },
    {
      "id": 8,
      "title": "Redis Memory Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "aws_elasticache_database_memory_usage_percentage_average{cache_cluster_id=~\"cloud-cost-optimizer-redis.*\"}",
          "legendFormat": "Memory Usage %",
          "refId": "A"
        }
      ],
      "yAxes": [
        {
          "label": "Percentage",
          "min": 0,
          "max": 100
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 16
      }
    },
    {
      "id": 9,
      "title": "Top API Endpoints by Response Time",
      "type": "table",
      "targets": [
        {
          "expr": "topk(10, avg_over_time(api_response_time_seconds[1h])) by (endpoint)",
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 22
      }
    },
    {
      "id": 10,
      "title": "Error Rate by Endpoint",
      "type": "table",
      "targets": [
        {
          "expr": "rate(api_errors_total[1h]) by (endpoint)",
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 22
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": false,
        "iconColor": "green",
        "query": "deployment",
        "type": "tags"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "query",
        "query": "label_values(environment)",
        "current": {
          "value": "production",
          "text": "production"
        }
      }
    ]
  }
}
